{
  "name": "pregnancy-nutrition-coach",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "generate-assets": "node scripts/generate-assets.js",
    "doctor": "npx expo-doctor",
    "export:android": "npx expo export --platform android --output-dir dist-smoke",
    "export:ios": "npx expo export --platform ios --output-dir dist-smoke-ios",
    "build:android:preview": "npx eas build --platform android --profile preview",
    "build:android": "npx eas build --platform android --profile production",
    "build:ios": "npx eas build --platform ios --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.0",
    "expo-build-properties": "~0.12.5",
    "expo-secure-store": "~13.0.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
